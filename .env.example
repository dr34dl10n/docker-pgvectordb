# ── PostgreSQL + pgvector ──────────────────────────────────────────────────
# Copy this file to .env and customise for your environment.
# These variables are referenced in docker-compose.yml as ${VAR_NAME}.
#
# SECURITY NOTE: When using with codebase-skill, deploy.sh --docker
# automatically reuses your existing CODEINDEX_DB_PASSWORD or generates
# a random one — it never uses the "postgres" default in production.
#
# For standalone usage (without codebase-skill), set a strong password below.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=codebase
# POSTGRES_PORT=5432